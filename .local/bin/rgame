#!/bin/bash

SPLIT_TUNNEL="mullvad-exclude"
GAMEMODE="gamemoderun"
HUD="mangohud"
STEAM_TEMPLATE="${SPLIT_TUNNEL} ${HUD} steam steam://rungameid"

GAMES=(
    # "Apex Legends"
    "League of Legends"
    "Ghostrunner"
    "Counter-Strike 2"
)

COMMANDS=(
    # "${STEAM_TEMPLATE}/1172470// +fps_max unlimited"
    "${SPLIT_TUNNEL} lolforlinuxinstaller"
    "/opt/Heroic/heroic heroic://launch/gog/1957528513"
    "${STEAM_TEMPLATE}/730// -sdlaudiodriver pipewire"
)

for manifest in $HOME/ssd/SteamLibrary/steamapps/appmanifest_*.acf; do
    name=$(grep -Po '\"name\"[ \t]+\"\K.*(?=")' "$manifest")
    if ! echo "$name" | grep "Proton" > /dev/null; then
        app_id=$(grep -Po '\"appid\"[ \t]+\"\K.*(?=")' "$manifest")
        inarray=$(echo ${GAMES[@]} | grep -o "$name" | wc -w)
        if [ $inarray -eq 0 ]; then
            command="${STEAM_TEMPLATE}/${app_id}"
            COMMANDS+=( "$command" )
            GAMES+=( "$name" )
        fi
    fi
done

declare -A GAMES_TO_COMMANDS

for ((i=0; $i<${#GAMES[@]}; i++))
do
    GAMES_TO_COMMANDS+=(["${GAMES[i]}"]="${COMMANDS[i]}")
done

GAME=$(printf "%s\n" "${GAMES[@]}" | fzf  --query="$1" --select-1 --exit-0)

[[ -n "$GAME" ]] || exit 0

COMMAND=${GAMES_TO_COMMANDS["$GAME"]}

tmux new -s "$GAME" -d || exit 1

run() {
    tmux send-keys -t "$GAME:1" "$1" C-m
}


run $HOME/.local/bin/single
run "${COMMAND}"
run "sleep 0"
# run "while pgrep ".*.exe"; do sleep 0; done && $HOME/.local/bin/dual && tmux kill-session"
