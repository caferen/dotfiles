#!/bin/bash

$HOME/.local/bin/single

TEMPLATE="mullvad-exclude gamemoderun mangohud steam steam://rungameid"

declare -A games= ( \
        ["apex"]="${TEMPLATE}/1172470 -eac_launcher_settings SettingsDX12.json +fps_max unlimited" \
    )

# let the process spawn so we don't exit the script immediately
sleep 30

while pgrep -x "r5apex_dx12.exe"; do
    sleep 5
done

$HOME/.local/bin/dual
