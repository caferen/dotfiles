#!/bin/bash


SPLIT_TUNNEL="mullvad-exclude"
GAMEMODE="gamemoderun"
HUD="mangohud"
STEAM_TEMPLATE="${SPLIT_TUNNEL} ${GAMEMODE} ${HUD} steam steam://rungameid"

GAMES=(
    "Apex Legends"
    "League of Legends"
)

COMMANDS=(
    "${STEAM_TEMPLATE}/1172470 -eac_launcher_settings SettingsDX12.json +fps_max unlimited"
    "${SPLIT_TUNNEL} lolforlinuxinstaller"
)

for manifest in $HOME/ssd/SteamLibrary/steamapps/appmanifest_*.acf; do
    app_id=$(grep -Po '\"appid\"[ \t]+\"\K.*(?=")' "$manifest")
    name=$(grep -Po '\"name\"[ \t]+\"\K.*(?=")' "$manifest")
    inarray=$(echo ${GAMES[@]} | grep -o "$name" | wc -w)
    if [ $inarray -eq 0 ]; then
        command="${STEAM_TEMPLATE}/${app_id}"
        COMMANDS+=( "$command" )
        GAMES+=( "$name" )
    fi
done

declare -A GAMES_TO_COMMANDS

for ((i=0; $i<${#GAMES[@]}; i++))
do
    GAMES_TO_COMMANDS+=(["${GAMES[i]}"]="${COMMANDS[i]}")
done

GAME=$(printf "%s\n" "${GAMES[@]}" | fzf  --query="$1" --multi --select-1 --exit-0)

echo ${GAMES_TO_COMMANDS["$GAME"]}


# $HOME/.local/bin/single
#
# # let the process spawn so we don't exit the script immediately
# sleep 30
#
# while pgrep -x "r5apex_dx12.exe"; do
#     sleep 5
# done
#
# $HOME/.local/bin/dual
