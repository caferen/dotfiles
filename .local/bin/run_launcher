#!/bin/bash
#
# use this instead:
# https://raw.githubusercontent.com/i3/i3/next/i3-sensible-terminal

isopen=$(pgrep -f LauncherTerminal | wc -w)

if [ $isopen -eq 0 ]; then
    alacritty --class LauncherTerminal --title "AlacrittyLauncher" \
        --config-file $HOME/.config/alacritty/launcher.yml --command "$HOME/.local/bin/launcher"
else
    pkill -f LauncherTerminal
fi
