#!/bin/bash

SPLIT_TUNNEL="mullvad-exclude"
HUD="mangohud"
SINGLE_MONITOR="$HOME/.local/bin/single"
DUAL_MONITOR="$HOME/.local/bin/dual"
TMUX_KILL="tmux kill-session"
WATCH_EXE="sleep 30 && while pgrep ".*.exe" > /dev/null; do sleep 5; done && ${DUAL_MONITOR} && ${TMUX_KILL}"


STEAM_TEMPLATE() {
    echo "${SINGLE_MONITOR} && ${SPLIT_TUNNEL} ${HUD} ${1} && ${WATCH_EXE}"
}

declare -A APPS_TO_COMMANDS

if which lolforlinuxinstaller &> /dev/null; then
    APPS_TO_COMMANDS+=( ["League of Legends"]="${SPLIT_TUNNEL} lolforlinuxinstaller" )
fi

exec_to_command() {
    if echo "$1" | grep steam; then
        command=$(STEAM_TEMPLATE "$1")
    fi

}

applications() {
    for application in $1/*.desktop; do
        app_name=$(awk '/Desktop Entry/{f=1} f && /^Name=.*/ {print; exit}' "$application" | grep -Po '^Name=\K.*' -)
        app_exec=$(awk '/Desktop Entry/{f=1} f && /^Exec=.*/ {print; exit}' "$application" | grep -Po '^Exec=\K.*' -)
        APPS_TO_COMMANDS+=(["${app_name}"]="${app_exec} && tmux kill-session")

        IFS=$'\n' app_action_names=($(awk '/Desktop Action/{f=1} f && /^Name=.*/ {print; next}' "$application" \
            | grep -Po '^Name=\K.*' -))
        IFS=$'\n' app_action_execs=($(awk '/Desktop Action/{f=1} f && /^Exec=.*/ {print; next}' "$application" \
            | grep -Po '^Exec=\K.*' -))

        if [ ${#app_action_names[@]} -ne 0 ]; then
            for ((i=0; $i<${#app_action_names[@]}; i++))
            do
                APPS_TO_COMMANDS+=(["${app_name}: ${app_action_names[i]}"]="${app_action_execs[i]} && ${TMUX_KILL}")
            done
        fi
    done
}

# applications /usr/share/applications
applications $HOME/.local/share/applications

APP=$(printf "%s\n" "${!APPS_TO_COMMANDS[@]}" | fzf  --query="$1" --select-1 --exit-0 )

[[ -n "$APP" ]] || exit 0

COMMAND=${APPS_TO_COMMANDS[$APP]}

TMUX_SESSION=$(echo "$APP" | tr .: _)
tmux new -s "$TMUX_SESSION" -d || exit 1

run() {
    tmux send-keys -t "$TMUX_SESSION:1" "$1" C-m
}

run "${COMMAND}"
