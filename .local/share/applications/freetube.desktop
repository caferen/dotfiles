[Desktop Entry]
Name=FreeTube
Exec=/opt/FreeTube/freetube --enable-features=UseOzonePlatform,WaylandWindowDecorations --ozone-platform=wayland
Terminal=false
Type=Application
Icon=freetube
StartupWMClass=FreeTube
Comment=A private YouTube client
MimeType=x-scheme-handler/freetube;
Categories=Network;
